{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "produtos/templates/*.ejs", "watch": true },
      { "include": "assests/**/*", "watch": true }
    ]
  }
}