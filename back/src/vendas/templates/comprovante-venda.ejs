<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            padding: 10mm;
            color: #2d3748;
            font-size: 11px;
            background-color: #ffffff;
            line-height: 1.4;
        }

        /* Estrutura de Topo - Corporativa e Limpa */
        .header-table {
            width: 100%;
            border-bottom: 2px solid #0b4624; /* Verde Petróleo Escuro */
            padding-bottom: 5mm;
            margin-bottom: 6mm;
        }

        .company-info h1 {
            color: #0b4624;
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 1.5mm;
            letter-spacing: 0.5px;
        }

        .company-info p {
            color: #4a5568;
            font-size: 10px;
        }

        .doc-info {
            text-align: right;
            vertical-align: bottom;
        }

        .doc-number {
            font-size: 15px;
            font-weight: bold;
            color: #0b4624;
            margin-bottom: 1.5mm;
            letter-spacing: 0.5px;
        }

        .doc-info p {
            font-size: 10.5px;
            color: #718096;
        }

        .doc-info strong {
            color: #2d3748;
        }

        /* Títulos de Seção Minimalistas e Sobrios */
        .section-title {
            background: #f0f5f1; /* Fundo verde acinzentado bem sutil */
            padding: 2mm 3mm;
            font-weight: bold;
            color: #0b4624;
            margin-top: 6mm;
            margin-bottom: 2.5mm;
            text-transform: uppercase;
            border-left: 3px solid #00cc44; /* Detalhe em Verde Vivo da logo */
            font-size: 10.5px;
            letter-spacing: 0.5px;
        }

        /* Tabelas de Informação com Design Clean */
        .info-table {
            width: 100%;
            margin-bottom: 4mm;
        }

        .info-table td {
            width: 50%;
            vertical-align: top;
            border: none;
            padding: 0;
        }

        .info-table td:first-child {
            padding-right: 3mm;
        }

        .info-table td:last-child {
            padding-left: 3mm;
        }

        .info-box {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 3px;
            padding: 4mm;
            min-height: 85px;
        }

        .info-box p {
            margin-bottom: 1.5mm;
            font-size: 10.5px;
            color: #4a5568;
        }

        .info-box strong {
            color: #2d3748;
            font-weight: 600;
        }

        /* Tabela Principal de Itens */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 3mm;
            table-layout: fixed;
        }

        th {
            background: #0b4624; /* Verde Escuro Institucional */
            color: white;
            padding: 3mm 2mm;
            text-align: left;
            font-size: 9px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        td {
            padding: 2.5mm 2mm;
            border-bottom: 1px solid #edf2f7;
            word-wrap: break-word;
            font-size: 10px;
            color: #2d3748;
        }

        .text-right {
            text-align: right;
        }

        .text-center {
            text-align: center;
        }

        /* Área de Fechamento de Valores */
        .totals-table-container {
            width: 100%;
            margin-top: 6mm;
        }

        .totals-table-container td {
            border: none;
            padding: 0;
            vertical-align: top;
        }

        .obs-box {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 3px;
            padding: 4mm;
            font-size: 10px;
            color: #4a5568;
            line-height: 1.5;
        }

        .totals-table {
            width: 300px;
            float: right;
            margin-top: 0;
        }

        .totals-table td {
            border: none;
            padding: 2mm 2.5mm;
            font-size: 10.5px;
            color: #4a5568;
        }

        .grand-total {
            font-size: 14px;
            font-weight: bold;
            color: #ffffff;
            background-color: #0b4624; /* Destaque corporativo no total geral */
        }
        
        .grand-total td {
            padding: 3mm 2.5mm;
            font-weight: 700;
            color: #ffffff;
        }

        .footer {
            margin-top: 15mm;
            text-align: center;
            color: #a0aec0;
            font-size: 9px;
            border-top: 1px solid #edf2f7;
            padding-top: 5mm;
            letter-spacing: 0.2px;
        }

        .address-box {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 3px;
            padding: 4mm;
            margin-top: 1mm;
        }

        .address-type {
            display: inline-block;
            background: #e2e8f0;
            color: #4a5568;
            padding: 0.8mm 2.5mm;
            border-radius: 3px;
            font-size: 8.5px;
            font-weight: bold;
            text-transform: uppercase;
            margin-bottom: 2.5mm;
        }

        .address-default {
            background: #0b4624;
            color: white;
        }

        /* Configuração de Colunas */
        .col-descricao { width: 26%; }
        .col-m3       { width: 7%; }
        .col-peso     { width: 10%; }
        .col-qtd      { width: 7%; }
        .col-preco    { width: 11%; }
        .col-desc-un  { width: 11%; }
        .col-desc-tot { width: 11%; }
        .col-total    { width: 11%; }

        /* Badge Corporativo de Desconto */
        .badge-desconto {
            display: inline-block;
            background: #f0f5f1;
            color: #0b4624;
            border: 1px solid #c6f6d5;
            border-radius: 2px;
            padding: 0.5mm 1.5mm;
            font-size: 8.5px;
            font-weight: 600;
            white-space: nowrap;
        }

        .sem-desconto {
            color: #a0aec0;
            font-size: 9px;
        }

        .produto-nome {
            display: inline-block;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 95%;
            color: #2d3748;
        }

        .produto-detalhes {
            display: inline-block;
            color: #718096;
            font-size: 8.5px;
            margin-left: 2px;
        }

        /* Linha de Totais da Tabela */
        .tr-totais {
            background: #f8fafc;
            font-weight: bold;
            border-top: 1px solid #cbd5e0;
            border-bottom: 2px solid #0b4624;
        }
        
        .tr-totais td {
            color: #0b4624;
            padding: 3mm 2mm;
            font-weight: 700;
        }
    </style>
</head>

<body>
<%
    /* ─────────────────────────────────────────────────────────
       Funções auxiliares de formatação (pt-BR)
       ───────────────────────────────────────────────────────── */
    function fmtNum(value, decimals) {
        return Number(value).toLocaleString('pt-BR', {
            minimumFractionDigits: decimals,
            maximumFractionDigits: decimals
        });
    }

    function fmtBRL(value) {
        return 'R$ ' + fmtNum(value, 2);
    }

    function fmtM3(value) {
        return fmtNum(value, 2);
    }

    function fmtKg(value) {
        return fmtNum(value, 2);
    }
%>
    <table class="header-table">
        <tr>
            <td style="border: none; padding: 0; width: 60%; vertical-align: top;">
                <div class="company-info">
                    <img src="<%= logoDataUri %>" style="height: 85px; margin-bottom: 2.5mm; display: block;">
                    <h1>FERNANDES MADEIRAS</h1>
                    <p>CNPJ: 50.775.091/0001-05 | Tel: (38) 99902-8181</p>
                </div>
            </td>
            <td style="border: none; padding: 0; width: 40%; text-align: right; vertical-align: bottom;">
                <div class="doc-info">
                    <p class="doc-number">PEDIDO DE VENDA N° <%= venda.numeroPedido %></p>
                    <p>Emissão: <strong><%= new Date(venda.createdAt).toLocaleDateString('pt-BR') %></strong></p>
                    <p>Status: <strong style="color: #00cc44;"><%= venda.statusVenda %></strong></p>
                </div>
            </td>
        </tr>
    </table>

    <table class="info-table">
        <tr>
            <td>
                <div class="section-title" style="margin-top: 0;">Dados do Cliente</div>
                <div class="info-box">
                    <p><strong>Nome/Razão Social:</strong> <%= venda.cliente?.nomeRazaoSocial || 'Consumidor Final' %></p>
                    <p><strong>CPF/CNPJ:</strong> <%= venda.cliente?.documento || '-' %></p>
                    <p><strong>Contato:</strong> <%= venda.cliente?.celular || 'Não informado' %></p>
                    <p><strong>E-mail:</strong> <%= venda.cliente?.email || 'Não informado' %></p>
                </div>
            </td>
            <td>
                <div class="section-title" style="margin-top: 0;">Informações Comerciais</div>
                <div class="info-box">
                    <p><strong>Vendedor:</strong> <%= venda.vendedor?.nome || 'Sistema' %></p>
                    <p><strong>Condição de Pagamento:</strong> <%= venda.formaPagamento?.nome || venda.status %></p>
                    <p><strong>Documento Fiscal:</strong> <%= venda.statusSefaz || 'Não gerada' %></p>
                    <p><strong>Finalidade:</strong> <%= venda.tipoPedido || 'Venda' %></p>
                </div>
            </td>
        </tr>
    </table>

    <% if (venda.enderecoEntrega) { %>
        <div class="section-title">Endereço de Logística / Entrega</div>
        <div class="address-box">
            <span class="address-type <%= venda.enderecoEntrega.padrao ? 'address-default' : '' %>">
                <%= venda.enderecoEntrega.tipoEndereco %> <% if (venda.enderecoEntrega.padrao) { %>(Principal)<% } %>
            </span>
            <p><strong>Logradouro:</strong> <%= venda.enderecoEntrega.logradouro %>, <%= venda.enderecoEntrega.numero %></p>
            <% if (venda.enderecoEntrega.complemento) { %>
                <p><strong>Complemento:</strong> <%= venda.enderecoEntrega.complemento %></p>
            <% } %>
            <p><strong>Bairro/Distrito:</strong> <%= venda.enderecoEntrega.bairro %> | <strong>Município:</strong> <%= venda.enderecoEntrega.cidade %> - <%= venda.enderecoEntrega.estado %></p>
            <p><strong>CEP:</strong> <%= venda.enderecoEntrega.cep %></p>
            <% if (venda.enderecoEntrega.observacoes) { %>
                <p style="margin-top: 2mm; color: #718096; font-size: 9.5px;"><strong>Diretrizes de Entrega:</strong> <%= venda.enderecoEntrega.observacoes %></p>
            <% } %>
        </div>
    <% } else if (venda.cliente) { %>
        <div class="section-title">Endereço de Logística / Entrega</div>
        <div style="background: #fff5f5; border: 1px solid #fed7d7; padding: 4mm; border-radius: 3px;">
            <p style="color: #c53030; margin: 0; font-size: 10.5px;">
                <strong>⚠ NOTIFICAÇÃO:</strong> Nenhum endereço logístico foi localizado ou vinculado para esta entrega.
            </p>
        </div>
    <% } %>

    <div class="section-title">Especificação dos Itens</div>
    <table>
        <thead>
            <tr>
                <th class="col-descricao">DESCRIÇÃO</th>
                <th class="col-m3 text-center">M³</th>
                <th class="col-peso text-right">PESO (kg)</th>
                <th class="col-qtd text-center">QTD</th>
                <th class="col-preco text-right">VALOR UN</th>
                <th class="col-desc-un text-right">DESC. UN</th>
                <th class="col-desc-tot text-right">DESC. TOTAL</th>
                <th class="col-total text-right">TOTAL LÍQ.</th>
            </tr>
        </thead>
        <tbody>
            <%
                let totalM3        = 0;
                let totalPeso      = 0;
                let totalQtd       = 0;
                let totalDescontos = 0;

                venda.itens.forEach(item => {
                    const produto = item.produto;

                    let m3Calculado = 0;
                    if (produto?.dimensao_ripa && produto?.comprimento_mt) {
                        const partes = produto.dimensao_ripa.split('x');
                        if (partes.length === 2) {
                            const medidas = partes.map(n => parseFloat(n.trim().replace(',', '.')));
                            const comprimento = parseFloat(String(produto.comprimento_mt).replace(',', '.'));
                            m3Calculado = ((medidas[0]/100) * (medidas[1]/100) * comprimento) * item.quantidade;
                        }
                    } else if (produto?.diametro_min && produto?.diametro_max && produto?.comprimento_mt) {
                        const dMin = parseFloat(String(produto.diametro_min).replace(',', '.'));
                        const dMax = parseFloat(String(produto.diametro_max).replace(',', '.'));
                        const comprimento = parseFloat(String(produto.comprimento_mt).replace(',', '.'));
                        const raioMedio = ((dMin + dMax) / 2) / 200;
                        m3Calculado = (Math.PI * Math.pow(raioMedio, 2) * comprimento) * item.quantidade;
                    }

                    if (!m3Calculado || m3Calculado === 0) {
                        m3Calculado = (parseFloat(produto?.m3_unitario) || 0) * item.quantidade;
                    }

                    const pesoTotal = (parseFloat(produto?.peso_unitario_kg) || 0) * item.quantidade;
                    const descontoTotal    = parseFloat(item.valorDesconto) || 0;
                    const descontoUnitario = item.quantidade > 0 ? descontoTotal / item.quantidade : 0;

                    totalM3          += m3Calculado;
                    totalPeso        += pesoTotal;
                    totalQtd         += item.quantidade;
                    totalDescontos   += descontoTotal;
            %>
            <tr>
                <td class="col-descricao">
                    <span class="produto-nome">
                        <strong><%= produto?.nome || 'Produto' %></strong>
                    </span>
                    <% if (produto?.dimensao_ripa) { %>
                        <span class="produto-detalhes">[<%= produto.dimensao_ripa %>]</span>
                    <% } %>
                    <% if (produto?.comprimento_mt) { %>
                        <span class="produto-detalhes"><%= produto.comprimento_mt %>m</span>
                    <% } %>
                </td>
                <td class="col-m3 text-center"><%= fmtM3(m3Calculado) %></td>
                <td class="col-peso text-right"><%= fmtKg(pesoTotal) %></td>
                <td class="col-qtd text-center"><%= item.quantidade.toFixed(1).replace('.', ',') %></td>
                <td class="col-preco text-right"><%= fmtBRL(item.valorUnitario) %></td>
                <td class="col-desc-un text-right">
                    <% if (descontoUnitario > 0) { %>
                        <span class="badge-desconto">-<%= fmtBRL(descontoUnitario) %></span>
                    <% } else { %>
                        <span class="sem-desconto">—</span>
                    <% } %>
                </td>
                <td class="col-desc-tot text-right">
                    <% if (descontoTotal > 0) { %>
                        <span class="badge-desconto">-<%= fmtBRL(descontoTotal) %></span>
                    <% } else { %>
                        <span class="sem-desconto">—</span>
                    <% } %>
                </td>
                <td class="col-total text-right" style="font-weight: 600;"><%= fmtBRL(item.valorSubtotal) %></td>
            </tr>
            <% }); %>

            <tr class="tr-totais">
                <td class="col-descricao text-right">TOTAL</td>
                <td class="col-m3 text-center"><%= fmtM3(totalM3) %></td>
                <td class="col-peso text-right"><%= fmtKg(totalPeso) %></td>
                <td class="col-qtd text-center"><%= totalQtd.toFixed(1).replace('.', ',') %></td>
                <td class="col-preco text-center"></td>
                <td class="col-desc-un text-right">—</td>
                <td class="col-desc-tot text-right">
                    <% if (totalDescontos > 0) { %>
                        - <%= fmtBRL(totalDescontos) %>
                    <% } else { %>—<% } %>
                </td>
                <td class="col-total text-right">
                    <%= fmtBRL(venda.valorProdutos) %>
                </td>
            </tr>
        </tbody>
    </table>

    <table class="totals-table-container">
        <tr>
            <td style="width: 55%;">
                <div class="obs-box">
                    <div style="font-weight: bold; margin-bottom: 1.5mm; color: #0b4624;">Observações Gerais do Pedido:</div>
                    <p><%= venda.observacoesCliente || 'Nenhuma observação registrada.' %></p>

                    <% if (venda.observacoesInternas) { %>
                        <div style="margin-top: 3mm; padding-top: 3mm; border-top: 1px dashed #cbd5e0;">
                            <div style="font-weight: bold; margin-bottom: 1.5mm; color: #718096;">Notas de Controle Interno:</div>
                            <p><%= venda.observacoesInternas %></p>
                        </div>
                    <% } %>
                </div>
            </td>
            <td style="width: 45%;">
                <table class="totals-table">
                    <tr>
                        <td>Subtotal dos Itens:</td>
                        <td class="text-right"><%= fmtBRL(venda.valorProdutos) %></td>
                    </tr>
                    <% if (venda.valorFrete > 0) { %>
                        <tr>
                            <td>Valor do Frete (+):</td>
                            <td class="text-right"><%= fmtBRL(venda.valorFrete) %></td>
                        </tr>
                    <% } %>
                    <% if (venda.valorDesconto > 0) { %>
                        <tr>
                            <td>Desconto Comercial (-):</td>
                            <td class="text-right" style="color: #0b4624; font-weight: 600;">
                                - <%= fmtBRL(venda.valorDesconto) %>
                            </td>
                        </tr>
                    <% } %>
                    <tr class="grand-total">
                        <td>TOTAL LIQUIDO:</td>
                        <td class="text-right"><%= fmtBRL(venda.valorTotal) %></td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <% if (venda.enderecoEntrega && venda.valorFrete > 0) { %>
        <div style="margin-top: 5mm; padding: 3.5mm; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 3px;">
            <div style="font-weight: bold; color: #0b4624; font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.3px;">Dados Complementares de Transporte</div>
            <p style="margin-top: 1mm; font-size: 10px; color: #4a5568;">
                <strong>Frete cobrado:</strong> <%= fmtBRL(venda.valorFrete) %>
                <% if (venda.prazoEntrega) { %>
                    | <strong>Prazo de Entrega:</strong> <%= venda.prazoEntrega %> dias úteis presumidos
                <% } %>
                <% if (venda.transportadora) { %>
                    | <strong>Logística por:</strong> <%= venda.transportadora %>
                <% } %>
            </p>
        </div>
    <% } %>

    <div class="footer">
        <p>Este documento consiste estritamente em um espelho de conferência de pedido mercantil, desprovido de valor fiscal de NFe.</p>
    </div>
</body>

</html>